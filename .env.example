# Copia in `.env.local` e compila con i dati reali della struttura.
# Obblighi di pubblicità per locazione turistica (Toscana / nazionale) — piè di pagina sul sito.

NEXT_PUBLIC_CIR=
# CIN nazionale (obbligatorio in pubblicità). Valore predefinito nel codice; sovrascrivere qui se serve.
NEXT_PUBLIC_CIN=IT046017C24BJQQTVV
# Predefinito nel codice (Jelena Mijailovic Pisciotta); valorizzare qui per sovrascrivere.
NEXT_PUBLIC_OPERATOR_NAME=
NEXT_PUBLIC_OPERATOR_VAT_OR_CF=
# Predefinito nel codice (Via Pelleria, 14, 55100 Lucca); valorizzare qui per sovrascrivere.
NEXT_PUBLIC_PROPERTY_ADDRESS=

# Export iCal segreto Airbnb (solo server, non esporre al client). Opzionale: senza URL la sezione mostra un invito a scrivervi.
# Airbnb → Annuncio → Disponibilità → Collega calendario → Esporta calendario → copia il link.
AIRBNB_ICAL_URL=
